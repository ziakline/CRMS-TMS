{
  "name": "crms-tms",
  "version": "1.0.0",
  "private": true,
  "description": "CRMS Tracking Management System",
  "scripts": {
    "clean:cache": "rimraf .next .turbo",
    "dev:prepare": "kill-port 3000 3001 || echo ports already clear",
    "dev:reset": "npm run dev:prepare && npm run clean:cache && next dev -p 3000",
    "dev": "npm run dev:reset",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "autoprefixer": "^10.4.21",
    "kill-port": "^2.0.1",
    "postcss": "^8.5.3",
    "prisma": "^5.22.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.14.0",
    "next": "^14.2.28",
    "next-auth": "^4.24.11",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  }
